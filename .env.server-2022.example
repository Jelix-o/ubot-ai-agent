# =========================================
# Windows Server 2022 部署环境变量模板
# 复制本文件为 .env 后再填写
# 适合同机部署：NapCat 和机器人在同一台服务器
# =========================================

# NapCat 接入模式
# 推荐 reverse
NAPCAT_MODE=reverse

# NapCat 正向 WebSocket 地址
# 只有在 forward 模式下才会使用
NAPCAT_WS_URL=

# NapCat 访问 token
# 必须和 NapCat 网络配置中的 token 保持一致
NAPCAT_ACCESS_TOKEN=

# 机器人监听的反向 WebSocket 主机地址
# 同机部署建议使用 127.0.0.1
NAPCAT_REVERSE_WS_HOST=127.0.0.1

# 机器人监听的反向 WebSocket 端口
NAPCAT_REVERSE_WS_PORT=6199

# 机器人监听的反向 WebSocket 路径
NAPCAT_REVERSE_WS_PATH=/onebot/ws

# 文本模型接口地址
OPENAI_BASE_URL=

# 文本模型 API Key
OPENAI_API_KEY=

# 文本模型名称
OPENAI_MODEL=

# 画像/记忆分析模型接口地址
# 留空时回退复用 OPENAI_*
PROFILE_AI_BASE_URL=

# 画像/记忆分析模型 API Key
PROFILE_AI_API_KEY=

# 画像/记忆分析模型名称
PROFILE_AI_MODEL=

# TTS 接口地址
TTS_BASE_URL=

# TTS API Key
TTS_API_KEY=

# TTS 模型名称
TTS_MODEL=

# TTS 音色
TTS_VOICE=

# TTS 音频格式
# 一般保持 wav
TTS_AUDIO_FORMAT=wav

# 可选的全局 TTS 风格提示
TTS_STYLE_HINT=

# TTS 失败时是否回退 NapCat AI 语音
TTS_ALLOW_NAPCAT_AI_FALLBACK=false

# 机器人 QQ 号
BOT_QQ=

# 公网后台，默认关闭
# 开启后建议只监听 127.0.0.1，再由 Nginx/HTTPS 反代到 bot.9958.uk
ADMIN_HTTP_ENABLED=false
ADMIN_HTTP_HOST=127.0.0.1
ADMIN_HTTP_PORT=6200
ADMIN_PUBLIC_BASE_URL=https://bot.9958.uk
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
