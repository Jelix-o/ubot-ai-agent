# =========================================
# UBot 环境变量模板
# 复制本文件为 .env 后再填写
# =========================================

# NapCat 接入模式
# 可选值：forward / reverse
# forward：机器人主动连接 NapCat
# reverse：NapCat 主动连接机器人
NAPCAT_MODE=reverse

# NapCat 正向 WebSocket 地址
# 仅在 NAPCAT_MODE=forward 时生效
NAPCAT_WS_URL=

# NapCat 的访问 token
# 正向和反向模式都建议填写
NAPCAT_ACCESS_TOKEN=

# 机器人反向 WebSocket 监听地址
# 如果和 NapCat 在同一台机器，通常填 127.0.0.1
# 如果要让其他机器上的 NapCat 来连，可改成 0.0.0.0
NAPCAT_REVERSE_WS_HOST=127.0.0.1

# 机器人反向 WebSocket 监听端口
NAPCAT_REVERSE_WS_PORT=6199

# 机器人反向 WebSocket 路径
NAPCAT_REVERSE_WS_PATH=/onebot/ws

# 文本模型接口地址
# 例如 OpenAI 兼容网关、MiMo 兼容地址等
OPENAI_BASE_URL=

# 文本模型 API Key
OPENAI_API_KEY=

# 文本模型名称
# 例如：gpt-4.1-mini / mimo-v2-pro / mimo-v2-omni
OPENAI_MODEL=

# 画像/记忆分析模型接口地址
# 留空时回退复用 OPENAI_*；生产可填 Mimo OpenAI 兼容地址
PROFILE_AI_BASE_URL=

# 画像/记忆分析模型 API Key
# 留空时回退复用 OPENAI_API_KEY
PROFILE_AI_API_KEY=

# 画像/记忆分析模型名称
# 例如：mimo-v2.5-pro
PROFILE_AI_MODEL=

# TTS 接口地址
# 如果你希望语音也走独立网关，就填写
# 如果和文本模型走同一个兼容接口，也可以填同一个地址
TTS_BASE_URL=

# TTS API Key
# 如果留空，项目会回退复用 OPENAI_API_KEY
TTS_API_KEY=

# TTS 模型名
# 例如：mimo-v2-tts
TTS_MODEL=

# TTS 音色
# 例如：mimo_default / default_zh / default_en
TTS_VOICE=

# TTS 输出音频格式
# 通常保留 wav 即可
TTS_AUDIO_FORMAT=wav

# 全局附加 TTS 风格提示
# 可留空
TTS_STYLE_HINT=

# TTS 失败时是否允许回退到 NapCat AI 语音
# true / false
TTS_ALLOW_NAPCAT_AI_FALLBACK=false

# 机器人自己的 QQ 号
BOT_QQ=

# 公网后台，默认关闭
# 生产建议通过 Nginx 将 https://bot.9958.uk 反代到 127.0.0.1:6200
ADMIN_HTTP_ENABLED=false
ADMIN_HTTP_HOST=127.0.0.1
ADMIN_HTTP_PORT=6200
ADMIN_PUBLIC_BASE_URL=https://bot.9958.uk
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
