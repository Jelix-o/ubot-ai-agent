{
  "name": "ubot",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && powershell -NoProfile -Command \"node --test --experimental-test-isolation=none (Get-ChildItem -Recurse dist -Filter *.test.js | ForEach-Object { $_.FullName })\"",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-win.ps1"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "openai": "^4.104.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
