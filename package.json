{
  "name": "ubot",
  "version": "4.7.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node scripts/run-node22.cjs node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "dev:admin": "node scripts/run-node22.cjs node_modules/vite/bin/vite.js --config admin/vite.config.ts",
    "start": "node dist/index.js",
    "build": "npm run build:admin && npm run build:server",
    "build:admin": "node scripts/run-node22.cjs node_modules/vite/bin/vite.js build --config admin/vite.config.ts",
    "build:server": "node scripts/run-node22.cjs node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "test": "npm run build && node scripts/run-tests.cjs",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-win.ps1"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "openai": "^4.104.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-router": "^4.6.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
